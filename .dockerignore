# =============================================================================
# Version control — Git history is never needed inside an image
# =============================================================================
.git/
.gitignore

# =============================================================================
# Secrets — .env must never enter the build context under any circumstances
# =============================================================================
.env
secrets/
*.pem
*.key
*.cert
*.p12

# =============================================================================
# Documentation — adds weight to the build context with no functional benefit
# =============================================================================
README.md
CLAUDE.md
docs/
*.md

# =============================================================================
# IDE & editor directories — not needed for compilation
# =============================================================================
.idea/
.vscode/

# =============================================================================
# OS-generated files — noise with no purpose in a build context
# =============================================================================
.DS_Store
.AppleDouble
Thumbs.db
Desktop.ini

# =============================================================================
# Test files — the production binary does not include or run tests
# =============================================================================
*_test.go

# =============================================================================
# Build artefacts & local output directories — stale binaries must not
# shadow the freshly compiled binary inside the builder stage
# =============================================================================
bin/
dist/
out/
tmp/

# =============================================================================
# Compose files — not meaningful inside the image itself
# =============================================================================
docker-compose*.yml

# =============================================================================
# Air live-reload config — development tool only
# =============================================================================
air.toml
