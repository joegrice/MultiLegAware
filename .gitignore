# =============================================================================
# Go
# =============================================================================

# Compiled binary (matches the output name used in Dockerfile and README)
journey-service
multilegaware

# Build output directories
bin/
dist/
out/

# Test cache, coverage, and race detector output
*.out
coverage.html
coverage.txt

# Go workspace files (not used in this project)
go.work
go.work.sum

# =============================================================================
# Secrets & Config
# =============================================================================

# Real env file — .env.example must never be ignored
.env

# TLS / certificate files
*.pem
*.key
*.cert
*.p12

# Secrets directory
secrets/

# =============================================================================
# Docker
# =============================================================================

# Local override file — should not be committed
docker-compose.override.yml

# =============================================================================
# IDEs & Editors — JetBrains (GoLand, Rider, etc.)
# =============================================================================
.idea/
*.iml

# =============================================================================
# IDEs & Editors — VS Code
# =============================================================================
# Ignore the whole directory except extensions.json (shareable with the team)
.vscode/*
!.vscode/extensions.json

# =============================================================================
# IDEs & Editors — Vim / Neovim
# =============================================================================
*.swp
*.swo
Session.vim

# =============================================================================
# IDEs & Editors — Emacs
# =============================================================================
*~
\#*\#

# =============================================================================
# OS — macOS
# =============================================================================
.DS_Store
.AppleDouble
.LSOverride

# =============================================================================
# OS — Linux
# =============================================================================
.directory
.Trash-*

# =============================================================================
# OS — Windows
# =============================================================================
Thumbs.db
Desktop.ini

# =============================================================================
# Misc
# =============================================================================

# Temporary and backup files
*.tmp
*.bak
*.log

# Air (Go live-reload tool) — tmp/ is Air's build directory; air.toml is
# project-specific and may or may not be committed intentionally.
tmp/
air.toml
